* text=auto eol=lf

# Shell scripts and Linux configs MUST have LF endings (run on Ubuntu)
*.sh text eol=lf
*.service text eol=lf
*.conf text eol=lf
deploy/* text eol=lf

# Python source: LF
*.py text eol=lf

# YAML/TOML/JSON: LF
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf

# Markdown: LF for consistency
*.md text eol=lf

# Templates: LF
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.pdf binary
